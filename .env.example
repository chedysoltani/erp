# ── Base de données MySQL ──────────────────────────────────────────────────────
# Mot de passe root MySQL (utilisé uniquement par le container MySQL)
DB_ROOT_PASSWORD=change_me_root_password

# Credentials de l'utilisateur applicatif
DB_NAME=sit_erp_db
DB_USER=erp_app_user
DB_PASSWORD=change_me_app_password

# ── Backend ───────────────────────────────────────────────────────────────────
# Clé JWT — générer avec : openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# Origines autorisées pour CORS (URL exacte du frontend, sans slash final)
ALLOWED_ORIGINS=https://app.votre-domaine.com

# Clé API Google Gemini (optionnel — uniquement pour les routes /api/ia)
GEMINI_API_KEY=your_gemini_api_key_here

# ── Docker image tagging ──────────────────────────────────────────────────────
# Dépôt GitHub au format owner/repo (ex: chedysoltani/windsurf-project-2)
GITHUB_REPOSITORY=your_github_username/windsurf-project-2

# Tag de l'image à déployer — "latest" ou un SHA court (ex: a1b2c3d)
IMAGE_TAG=latest
